# Tennis Scout — variabili d'ambiente
# Copia questo file in .env e compila i valori

# ── OBBLIGATORIA ──────────────────────────────────────────────────────────────
# La tua API key di Anthropic (ottienila su console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPZIONALI ─────────────────────────────────────────────────────────────────
# Percorso del database SQLite (default: ./tennis_scout.db)
DB_PATH=tennis_scout.db

# Porta del server (default: 8000)
PORT=8000
